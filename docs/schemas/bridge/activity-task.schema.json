{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mfow/ocaml-temporal/docs/schemas/bridge/activity-task.schema.json",
  "title": "Remote activity task",
  "description": "A closed semantic remote-activity task sent from the Rust Temporal Core bridge to the private OCaml activity runner.",
  "type": "object",
  "additionalProperties": false,
  "required": ["task_token", "variant"],
  "properties": {
    "task_token": {"$ref": "#/$defs/task_token"},
    "variant": {"$ref": "#/$defs/task_variant"}
  },
  "$defs": {
    "payload": {"$ref": "temporal-payload.schema.json"},
    "identifier": {"type": "string", "minLength": 1, "maxLength": 65536},
    "bounded_string": {"type": "string", "maxLength": 65536},
    "task_token": {
      "type": "string",
      "minLength": 4,
      "maxLength": 178956972,
      "pattern": "^(?:[A-Za-z0-9+/]{4})*(?:[A-Za-z0-9+/]{2}==|[A-Za-z0-9+/]{3}=)?$"
    },
    "u32": {"type": "integer", "minimum": 0, "maximum": 4294967295},
    "u64_decimal": {"type": "string", "pattern": "^(?:0|[1-9][0-9]{0,19})$"},
    "timestamp": {
      "type": "object",
      "additionalProperties": false,
      "required": ["seconds", "nanoseconds"],
      "properties": {
        "seconds": {"type": "integer", "minimum": -9223372036854775808, "maximum": 9223372036854775807},
        "nanoseconds": {"type": "integer", "minimum": 0, "maximum": 999999999}
      }
    },
    "duration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["seconds", "nanoseconds"],
      "properties": {
        "seconds": {"type": "integer", "minimum": 0, "maximum": 9223372036854775807},
        "nanoseconds": {"type": "integer", "minimum": 0, "maximum": 999999999}
      }
    },
    "nullable_timestamp": {"oneOf": [{"$ref": "#/$defs/timestamp"}, {"type": "null"}]},
    "nullable_duration": {"oneOf": [{"$ref": "#/$defs/duration"}, {"type": "null"}]},
    "workflow_execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workflow_id", "run_id"],
      "properties": {
        "workflow_id": {"$ref": "#/$defs/identifier"},
        "run_id": {"$ref": "#/$defs/identifier"}
      }
    },
    "workflow_priority": {
      "type": "object",
      "additionalProperties": false,
      "required": ["priority_key", "fairness_key", "fairness_weight_bits"],
      "properties": {
        "priority_key": {"type": "integer", "minimum": 0, "maximum": 2147483647},
        "fairness_key": {"type": "string", "maxLength": 64, "pattern": "^[^\\u0000]*$"},
        "fairness_weight_bits": {"$ref": "#/$defs/u32"}
      }
    },
    "retry_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["initial_interval", "backoff_coefficient_bits", "maximum_interval", "maximum_attempts", "non_retryable_error_types"],
      "properties": {
        "initial_interval": {"$ref": "#/$defs/nullable_duration"},
        "backoff_coefficient_bits": {"$ref": "#/$defs/u64_decimal"},
        "maximum_interval": {"$ref": "#/$defs/nullable_duration"},
        "maximum_attempts": {"type": "integer", "minimum": -2147483648, "maximum": 2147483647},
        "non_retryable_error_types": {
          "type": "array",
          "maxItems": 201326592,
          "items": {"$ref": "#/$defs/bounded_string"}
        }
      }
    },
    "activity_start": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "workflow_namespace", "workflow_type", "workflow_execution", "activity_id", "activity_type", "header_fields", "input", "heartbeat_details", "scheduled_time", "current_attempt_scheduled_time", "started_time", "attempt", "schedule_to_close_timeout", "start_to_close_timeout", "heartbeat_timeout", "retry_policy", "priority", "standalone_run_id"],
      "properties": {
        "kind": {"const": "start"},
        "workflow_namespace": {"$ref": "#/$defs/identifier"},
        "workflow_type": {"$ref": "#/$defs/identifier"},
        "workflow_execution": {"$ref": "#/$defs/workflow_execution"},
        "activity_id": {"$ref": "#/$defs/identifier"},
        "activity_type": {"$ref": "#/$defs/identifier"},
        "header_fields": {
          "type": "object",
          "maxProperties": 201326592,
          "propertyNames": {"$ref": "#/$defs/identifier"},
          "additionalProperties": {"$ref": "#/$defs/payload"}
        },
        "input": {"type": "array", "maxItems": 201326592, "items": {"$ref": "#/$defs/payload"}},
        "heartbeat_details": {"type": "array", "maxItems": 201326592, "items": {"$ref": "#/$defs/payload"}},
        "scheduled_time": {"$ref": "#/$defs/nullable_timestamp"},
        "current_attempt_scheduled_time": {"$ref": "#/$defs/nullable_timestamp"},
        "started_time": {"$ref": "#/$defs/nullable_timestamp"},
        "attempt": {"$ref": "#/$defs/u32"},
        "schedule_to_close_timeout": {"$ref": "#/$defs/nullable_duration"},
        "start_to_close_timeout": {"$ref": "#/$defs/nullable_duration"},
        "heartbeat_timeout": {"$ref": "#/$defs/nullable_duration"},
        "retry_policy": {"oneOf": [{"$ref": "#/$defs/retry_policy"}, {"type": "null"}]},
        "priority": {"oneOf": [{"$ref": "#/$defs/workflow_priority"}, {"type": "null"}]},
        "standalone_run_id": {"$ref": "#/$defs/bounded_string"}
      }
    },
    "cancellation_details": {
      "type": "object",
      "additionalProperties": false,
      "required": ["is_not_found", "is_cancelled", "is_paused", "is_timed_out", "is_worker_shutdown", "is_reset"],
      "properties": {
        "is_not_found": {"type": "boolean"},
        "is_cancelled": {"type": "boolean"},
        "is_paused": {"type": "boolean"},
        "is_timed_out": {"type": "boolean"},
        "is_worker_shutdown": {"type": "boolean"},
        "is_reset": {"type": "boolean"}
      }
    },
    "activity_cancel": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "reason", "details"],
      "properties": {
        "kind": {"const": "cancel"},
        "reason": {"enum": ["not_found", "cancelled", "timed_out", "worker_shutdown", "paused", "reset"]},
        "details": {"oneOf": [{"$ref": "#/$defs/cancellation_details"}, {"type": "null"}]}
      }
    },
    "task_variant": {
      "oneOf": [
        {"$ref": "#/$defs/activity_start"},
        {"$ref": "#/$defs/activity_cancel"}
      ]
    }
  }
}
