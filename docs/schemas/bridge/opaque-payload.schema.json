{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mfow/ocaml-temporal/docs/schemas/bridge/opaque-payload.schema.json",
  "title": "OCaml Temporal private opaque payload",
  "type": "object",
  "additionalProperties": false,
  "required": ["encoding", "data"],
  "properties": {
    "encoding": { "const": "base64" },
    "data": {
      "type": "string",
      "maxLength": 349528,
      "pattern": "^(?:[A-Za-z0-9+/]{4})*(?:[A-Za-z0-9+/]{2}==|[A-Za-z0-9+/]{3}=)?$"
    }
  }
}
