{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mfow/ocaml-temporal/docs/schemas/acceptance/patch-replay-history.schema.json",
  "title": "Normalized workflow-patch replay history",
  "description": "Payload-free projection of one Temporal history used by the old/new workflow-patch acceptance. The normalizer retains only execution identity, ordered event IDs and types, the durable Core patch marker, and an ActivityTaskScheduled activity type. The shell validator enforces stage-specific ordering and exact initial-to-terminal prefix equality.",
  "type": "object",
  "additionalProperties": false,
  "required": ["workflow_id", "run_id", "events"],
  "properties": {
    "workflow_id": {"$ref": "#/$defs/identifier"},
    "run_id": {"$ref": "#/$defs/identifier"},
    "events": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1000000,
      "items": {"$ref": "#/$defs/event"}
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 65536,
      "pattern": "^[^\\u0000-\\u001f\\u007f]*$"
    },
    "event_id": {
      "type": "string",
      "pattern": "^(?:[1-9][0-9]{0,17}|[1-8][0-9]{18}|9[01][0-9]{17}|92[01][0-9]{16}|922[0-2][0-9]{15}|9223[0-2][0-9]{14}|92233[0-6][0-9]{13}|922337[01][0-9]{12}|92233720[0-2][0-9]{10}|922337203[0-5][0-9]{9}|9223372036[0-7][0-9]{8}|92233720368[0-4][0-9]{7}|922337203685[0-3][0-9]{6}|9223372036854[0-6][0-9]{5}|92233720368547[0-6][0-9]{4}|922337203685477[0-4][0-9]{3}|9223372036854775[0-7][0-9]{2}|922337203685477580[0-6]|9223372036854775807)$",
      "description": "Canonical positive signed-64-bit event ID in decimal text. JSON numbers are excluded because they cannot represent every Temporal event ID exactly."
    },
    "plain_event_type": {
      "type": "string",
      "enum": [
        "WorkflowExecutionStarted",
        "WorkflowTaskScheduled",
        "WorkflowTaskStarted",
        "WorkflowTaskCompleted",
        "WorkflowTaskFailed",
        "WorkflowTaskTimedOut",
        "TimerStarted",
        "TimerFired",
        "TimerCanceled",
        "ActivityTaskStarted",
        "ActivityTaskCompleted",
        "ActivityTaskFailed",
        "ActivityTaskCanceled",
        "UpsertWorkflowSearchAttributes",
        "WorkflowExecutionCompleted",
        "WorkflowExecutionFailed",
        "WorkflowExecutionCanceled",
        "WorkflowExecutionTerminated",
        "WorkflowExecutionTimedOut",
        "WorkflowExecutionContinuedAsNew"
      ]
    },
    "plain_event": {
      "type": "object",
      "additionalProperties": false,
      "required": ["event_id", "type"],
      "properties": {
        "event_id": {"$ref": "#/$defs/event_id"},
        "type": {"$ref": "#/$defs/plain_event_type"}
      }
    },
    "activity_scheduled": {
      "type": "object",
      "additionalProperties": false,
      "required": ["event_id", "type", "activity_type"],
      "properties": {
        "event_id": {"$ref": "#/$defs/event_id"},
        "type": {"const": "ActivityTaskScheduled"},
        "activity_type": {"$ref": "#/$defs/identifier"}
      }
    },
    "core_patch_marker": {
      "type": "object",
      "additionalProperties": false,
      "required": ["event_id", "type", "marker_name", "patch_id", "deprecated"],
      "properties": {
        "event_id": {"$ref": "#/$defs/event_id"},
        "type": {"const": "MarkerRecorded"},
        "marker_name": {"const": "core_patch"},
        "patch_id": {"$ref": "#/$defs/identifier"},
        "deprecated": {"const": false}
      }
    },
    "event": {
      "oneOf": [
        {"$ref": "#/$defs/plain_event"},
        {"$ref": "#/$defs/activity_scheduled"},
        {"$ref": "#/$defs/core_patch_marker"}
      ]
    }
  }
}
