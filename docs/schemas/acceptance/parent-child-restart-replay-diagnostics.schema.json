{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mfow/ocaml-temporal/docs/schemas/acceptance/parent-child-restart-replay-diagnostics.schema.json",
  "title": "Parent-child restart-replay worker diagnostics",
  "description": "Payload-free observer records for one parent workflow and its child. Root parent and child identity objects bind the record stream to exact runs. Before source replacement the stream contains exactly the two generation-one initial records in role order; after replacement it preserves those records and appends exactly the two generation-two replay records in the same role order.",
  "type": "object",
  "additionalProperties": false,
  "required": ["parent", "child", "records"],
  "properties": {
    "parent": {"$ref": "#/$defs/execution_identity"},
    "child": {"$ref": "#/$defs/execution_identity"},
    "records": {
      "oneOf": [
        {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "prefixItems": [
            {"$ref": "#/$defs/parent_initial"},
            {"$ref": "#/$defs/child_initial"}
          ],
          "items": false
        },
        {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "prefixItems": [
            {"$ref": "#/$defs/parent_initial"},
            {"$ref": "#/$defs/child_initial"},
            {"$ref": "#/$defs/parent_replay"},
            {"$ref": "#/$defs/child_replay"}
          ],
          "items": false
        }
      ]
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4096,
      "pattern": "^[^\\u0000-\\u001f\\u007f]*$",
      "description": "The schema limit is JSON character count. The executable validator additionally caps the UTF-8 encoding at 4096 bytes before an identifier crosses the native boundary."
    },
    "positive_signed_64": {
      "type": "string",
      "pattern": "^(?:[1-9][0-9]{0,17}|[1-8][0-9]{18}|9[01][0-9]{17}|92[01][0-9]{16}|922[0-2][0-9]{15}|9223[0-2][0-9]{14}|92233[0-6][0-9]{13}|922337[01][0-9]{12}|92233720[0-2][0-9]{10}|922337203[0-5][0-9]{9}|9223372036[0-7][0-9]{8}|92233720368[0-4][0-9]{7}|922337203685[0-3][0-9]{6}|9223372036854[0-6][0-9]{5}|92233720368547[0-6][0-9]{4}|922337203685477[0-4][0-9]{3}|9223372036854775[0-7][0-9]{2}|922337203685477580[0-6]|9223372036854775807)$",
      "description": "Canonical positive signed-64-bit decimal text. Counts remain strings so the protocol never depends on a JSON number implementation's precision limits."
    },
    "execution_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workflow_id", "run_id"],
      "properties": {
        "workflow_id": {"$ref": "#/$defs/identifier"},
        "run_id": {"$ref": "#/$defs/identifier"}
      }
    },
    "record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "phase", "generation", "is_replaying", "history_length"],
      "properties": {
        "role": {"enum": ["parent", "child"]},
        "phase": {"enum": ["initial", "replay"]},
        "generation": {"enum": [1, 2]},
        "is_replaying": {"type": "boolean"},
        "history_length": {"$ref": "#/$defs/positive_signed_64"}
      }
    },
    "parent_initial": {
      "allOf": [
        {"$ref": "#/$defs/record"},
        {
          "properties": {
            "role": {"const": "parent"},
            "phase": {"const": "initial"},
            "generation": {"const": 1},
            "is_replaying": {"const": false}
          }
        }
      ]
    },
    "child_initial": {
      "allOf": [
        {"$ref": "#/$defs/record"},
        {
          "properties": {
            "role": {"const": "child"},
            "phase": {"const": "initial"},
            "generation": {"const": 1},
            "is_replaying": {"const": false}
          }
        }
      ]
    },
    "parent_replay": {
      "allOf": [
        {"$ref": "#/$defs/record"},
        {
          "properties": {
            "role": {"const": "parent"},
            "phase": {"const": "replay"},
            "generation": {"const": 2},
            "is_replaying": {"const": true}
          }
        }
      ]
    },
    "child_replay": {
      "allOf": [
        {"$ref": "#/$defs/record"},
        {
          "properties": {
            "role": {"const": "child"},
            "phase": {"const": "replay"},
            "generation": {"const": 2},
            "is_replaying": {"const": true}
          }
        }
      ]
    }
  }
}
