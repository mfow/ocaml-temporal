{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mfow/ocaml-temporal/docs/schemas/bridge/client-poll-update-request.schema.json",
  "title": "OCaml Temporal native client workflow update poll request",
  "type": "object",
  "additionalProperties": false,
