{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mfow/ocaml-temporal/docs/schemas/bridge/client-error.schema.json",
  "title": "OCaml Temporal native client error body",
  "description": "Closed JSON error body returned in the ABI error buffer for client start and wait operations. Server diagnostic text is deliberately not copied.",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "workflow_id", "existing_run_id"],
      "properties": {
        "kind": {"const": "already_started"},
        "workflow_id": {"type": "string", "minLength": 1},
        "existing_run_id": {"anyOf": [{"type": "string", "minLength": 1}, {"type": "null"}]}
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "code"],
      "properties": {
        "kind": {"const": "rpc"},
        "code": {"type": "string", "minLength": 1}
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "code"],
      "properties": {
        "kind": {"const": "protocol"},
        "code": {"type": "string", "minLength": 1}
      }
    }
  ]
}
