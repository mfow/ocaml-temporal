{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mfow/ocaml-temporal/docs/schemas/bridge/activity-completion.schema.json",
  "title": "Remote activity completion",
  "description": "A closed terminal remote-activity completion sent from the private OCaml activity runner to the Rust Temporal Core bridge.",
  "type": "object",
  "additionalProperties": false,
  "required": ["task_token", "result"],
  "properties": {
    "task_token": {"$ref": "#/$defs/task_token"},
    "result": {"$ref": "#/$defs/completion_result"}
  },
  "$defs": {
    "payload": {"$ref": "temporal-payload.schema.json"},
    "failure": {"$ref": "temporal-failure.schema.json"},
    "task_token": {
      "type": "string",
      "minLength": 4,
      "maxLength": 178956972,
      "pattern": "^(?:[A-Za-z0-9+/]{4})*(?:[A-Za-z0-9+/]{2}==|[A-Za-z0-9+/]{3}=)?$"
    },
    "completion_result": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "result"],
          "properties": {
            "kind": {"const": "completed"},
            "result": {"oneOf": [{"$ref": "#/$defs/payload"}, {"type": "null"}]}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "failure"],
          "properties": {
            "kind": {"const": "failed"},
            "failure": {"$ref": "#/$defs/failure"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "failure"],
          "properties": {
            "kind": {"const": "cancelled"},
            "failure": {"$ref": "#/$defs/failure"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind"],
          "properties": {"kind": {"const": "will_complete_async"}}
        }
      ]
    }
  }
}
