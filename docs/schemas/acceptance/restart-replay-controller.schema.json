{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mfow/ocaml-temporal/docs/schemas/acceptance/restart-replay-controller.schema.json",
  "title": "Worker restart/replay controller evidence",
  "description": "A payload-free, ordered record of the lifecycle observations emitted by the two-generation Temporal restart/replay controller. The live controller records the exact workflow identity, initial and terminal history checks, graceful or forced worker replacement, replay marker, graceful teardown, and PostgreSQL volume removal.",
  "type": "object",
  "additionalProperties": false,
  "required": ["workflow_id", "run_id", "events"],
  "properties": {
    "workflow_id": {"$ref": "#/$defs/identifier"},
    "run_id": {"$ref": "#/$defs/identifier"},
    "events": {
      "type": "array",
      "minItems": 13,
      "maxItems": 13,
      "prefixItems": [
        {"$ref": "#/$defs/stack_ready"},
        {"$ref": "#/$defs/driver_accepted"},
        {"$ref": "#/$defs/history_checked"},
        {"$ref": "#/$defs/driver_waiting"},
        {"$ref": "#/$defs/generation_one_replaced"},
        {"$ref": "#/$defs/generation_one_removed"},
        {"$ref": "#/$defs/generation_two_ready"},
        {"$ref": "#/$defs/replay_observed"},
        {"$ref": "#/$defs/history_checked"},
        {"$ref": "#/$defs/driver_completed"},
        {"$ref": "#/$defs/generation_two_stopped"},
        {"$ref": "#/$defs/generation_two_removed"},
        {"$ref": "#/$defs/volume_removed"}
      ],
      "items": false
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 65536,
      "pattern": "^[^\\u0000-\\u001f\\u007f]*$"
    },
    "container_id": {
      "type": "string",
      "minLength": 12,
      "maxLength": 64,
      "pattern": "^[a-f0-9]{12,64}$"
    },
    "non_negative_count": {
      "type": "integer",
      "minimum": 0,
      "maximum": 1000000
    },
    "positive_event_count": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1000000
    },
    "positive_signed_64_decimal": {
      "type": "string",
      "pattern": "^(?:[1-9][0-9]{0,17}|[1-8][0-9]{18}|9[01][0-9]{17}|92[01][0-9]{16}|922[0-2][0-9]{15}|9223[0-2][0-9]{14}|92233[0-6][0-9]{13}|922337[01][0-9]{12}|92233720[0-2][0-9]{10}|922337203[0-5][0-9]{9}|9223372036[0-7][0-9]{8}|92233720368[0-4][0-9]{7}|922337203685[0-3][0-9]{6}|9223372036854[0-6][0-9]{5}|92233720368547[0-6][0-9]{4}|922337203685477[0-4][0-9]{3}|9223372036854775[0-7][0-9]{2}|922337203685477580[0-6]|9223372036854775807)$",
      "description": "Canonical positive signed-64-bit history length in decimal text."
    },
    "status": {"const": "ok"},
    "stack_ready": {
      "type": "object",
      "additionalProperties": false,
      "required": ["step", "status", "stale_project_volumes_before_cleanup", "remaining_project_volumes_before_start", "temporal_healthy"],
      "properties": {
        "step": {"const": "stack_ready"},
        "status": {"$ref": "#/$defs/status"},
        "stale_project_volumes_before_cleanup": {"$ref": "#/$defs/non_negative_count"},
        "remaining_project_volumes_before_start": {"const": 0},
        "temporal_healthy": {"const": true}
      }
    },
    "driver_accepted": {
      "type": "object",
      "additionalProperties": false,
      "required": ["step", "status", "workflow_id", "run_id"],
      "properties": {
        "step": {"const": "driver_accepted"},
        "status": {"$ref": "#/$defs/status"},
        "workflow_id": {"$ref": "#/$defs/identifier"},
        "run_id": {"$ref": "#/$defs/identifier"}
      }
    },
    "history_checked": {
      "type": "object",
      "additionalProperties": false,
      "required": ["step", "status", "stage", "event_count"],
      "properties": {
        "step": {"const": "history_checked"},
        "status": {"$ref": "#/$defs/status"},
        "stage": {"enum": ["initial", "terminal"]},
        "event_count": {"$ref": "#/$defs/positive_event_count"}
      }
    },
    "driver_waiting": {
      "type": "object",
      "additionalProperties": false,
      "required": ["step", "status"],
      "properties": {
        "step": {"const": "driver_waiting"},
        "status": {"$ref": "#/$defs/status"}
      }
    },
    "generation_one_replaced": {
      "type": "object",
      "additionalProperties": false,
      "required": ["step", "status", "generation", "container_id", "exit_code", "replacement_mode", "shutdown_marker"],
      "properties": {
        "step": {"const": "generation_one_replaced"},
        "status": {"$ref": "#/$defs/status"},
        "generation": {"const": 1},
        "container_id": {"$ref": "#/$defs/container_id"},
        "exit_code": {"type": "integer", "minimum": 0, "maximum": 255},
        "replacement_mode": {"enum": ["graceful", "crash"]},
        "shutdown_marker": {"type": "boolean"}
      },
      "allOf": [
        {
          "if": {"properties": {"replacement_mode": {"const": "graceful"}}},
          "then": {"properties": {"exit_code": {"const": 0}, "shutdown_marker": {"const": true}}}
        },
        {
          "if": {"properties": {"replacement_mode": {"const": "crash"}}},
          "then": {"properties": {"exit_code": {"const": 137}, "shutdown_marker": {"const": false}}}
        }
      ]
    },
    "generation_one_removed": {
      "type": "object",
      "additionalProperties": false,
      "required": ["step", "status", "generation", "container_id", "remaining_worker_containers"],
      "properties": {
        "step": {"const": "generation_one_removed"},
        "status": {"$ref": "#/$defs/status"},
        "generation": {"const": 1},
        "container_id": {"$ref": "#/$defs/container_id"},
        "remaining_worker_containers": {"const": 0}
      }
    },
    "generation_two_ready": {
      "type": "object",
      "additionalProperties": false,
      "required": ["step", "status", "generation", "container_id", "readiness_generation", "fresh_container"],
      "properties": {
        "step": {"const": "generation_two_ready"},
        "status": {"$ref": "#/$defs/status"},
        "generation": {"const": 2},
        "container_id": {"$ref": "#/$defs/container_id"},
        "readiness_generation": {"const": 2},
        "fresh_container": {"const": true}
      }
    },
    "replay_observed": {
      "type": "object",
      "additionalProperties": false,
      "required": ["step", "status", "generation", "is_replaying", "history_length"],
      "properties": {
        "step": {"const": "replay_observed"},
        "status": {"$ref": "#/$defs/status"},
        "generation": {"const": 2},
        "is_replaying": {"const": true},
        "history_length": {"$ref": "#/$defs/positive_signed_64_decimal"}
      }
    },
    "driver_completed": {
      "type": "object",
      "additionalProperties": false,
      "required": ["step", "status", "outcome"],
      "properties": {
        "step": {"const": "driver_completed"},
        "status": {"$ref": "#/$defs/status"},
        "outcome": {"const": "completed"}
      }
    },
    "volume_removed": {
      "type": "object",
      "additionalProperties": false,
      "required": ["step", "status", "remaining_project_volumes"],
      "properties": {
        "step": {"const": "postgres_volume_removed"},
        "status": {"$ref": "#/$defs/status"},
        "remaining_project_volumes": {"const": 0}
      }
    },
    "generation_two_stopped": {
      "type": "object",
      "additionalProperties": false,
      "required": ["step", "status", "generation", "container_id", "exit_code", "shutdown_marker"],
      "properties": {
        "step": {"const": "generation_two_stopped"},
        "status": {"$ref": "#/$defs/status"},
        "generation": {"const": 2},
        "container_id": {"$ref": "#/$defs/container_id"},
        "exit_code": {"const": 0},
        "shutdown_marker": {"const": true}
      }
    },
    "generation_two_removed": {
      "type": "object",
      "additionalProperties": false,
      "required": ["step", "status", "generation", "container_id", "remaining_worker_containers"],
      "properties": {
        "step": {"const": "generation_two_removed"},
        "status": {"$ref": "#/$defs/status"},
        "generation": {"const": 2},
        "container_id": {"$ref": "#/$defs/container_id"},
        "remaining_worker_containers": {"const": 0}
      }
    }
  }
}
