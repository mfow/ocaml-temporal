{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mfow/ocaml-temporal/docs/schemas/bridge/workflow-completion.schema.json",
  "title": "Workflow completion",
  "description": "A closed semantic command batch sent from the private OCaml workflow runtime to the Rust Temporal Core bridge.",
  "type": "object",
  "additionalProperties": false,
  "required": ["run_id", "commands"],
  "properties": {
    "run_id": {"$ref": "#/$defs/identifier"},
    "commands": {"type": "array", "maxItems": 201326592, "items": {"$ref": "#/$defs/command"}}
  },
  "$defs": {
    "payload": {"$ref": "temporal-payload.schema.json"},
    "failure": {"$ref": "temporal-failure.schema.json"},
    "identifier": {"type": "string", "minLength": 1, "maxLength": 65536, "pattern": "^[^\\u0000]+$"},
    "u32": {"type": "integer", "minimum": 0, "maximum": 4294967295},
    "duration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["seconds", "nanoseconds"],
      "properties": {
        "seconds": {"type": "integer", "minimum": 0, "maximum": 9223372036854775807},
        "nanoseconds": {"type": "integer", "minimum": 0, "maximum": 999999999}
      }
    },
    "nullable_duration": {"oneOf": [{"$ref": "#/$defs/duration"}, {"type": "null"}]},
    "nullable_payload": {"oneOf": [{"$ref": "#/$defs/payload"}, {"type": "null"}]},
    "retry_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["initial_interval", "backoff_coefficient_bits", "maximum_interval", "maximum_attempts", "non_retryable_error_types"],
      "properties": {
        "initial_interval": {"$ref": "#/$defs/duration"},
        "backoff_coefficient_bits": {
          "type": "string",
          "pattern": "^(0|[1-9][0-9]{0,19})$",
          "description": "Canonical unsigned 64-bit decimal containing the IEEE-754 bits of a finite backoff coefficient at least 1.0. Runtime validation also enforces the exact unsigned range and floating-point value."
        },
        "maximum_interval": {"$ref": "#/$defs/duration"},
        "maximum_attempts": {"type": "integer", "minimum": 0, "maximum": 2147483647},
        "non_retryable_error_types": {
          "type": "array",
          "maxItems": 201326592,
          "items": {"$ref": "#/$defs/identifier"}
        }
      },
      "description": "An activity retry policy. The initial interval is positive and the maximum interval is at least as large; zero maximum attempts means unlimited attempts. The coefficient's decimal text is used instead of a JSON number so both language sides preserve its IEEE-754 bits."
    },
    "command": {
      "oneOf": [
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "seq", "activity_id", "activity_type", "task_queue", "arguments", "schedule_to_close_timeout", "schedule_to_start_timeout", "start_to_close_timeout", "heartbeat_timeout", "retry_policy", "cancellation_type", "do_not_eagerly_execute"],
          "anyOf": [
            {"properties": {"schedule_to_close_timeout": {"not": {"type": "null"}}}},
            {"properties": {"start_to_close_timeout": {"not": {"type": "null"}}}}
          ],
          "properties": {
            "kind": {"const": "schedule_activity"},
            "seq": {"$ref": "#/$defs/u32"},
            "activity_id": {"$ref": "#/$defs/identifier"},
            "activity_type": {"$ref": "#/$defs/identifier"},
            "task_queue": {"$ref": "#/$defs/identifier"},
            "arguments": {"type": "array", "maxItems": 201326592, "items": {"$ref": "#/$defs/payload"}},
            "schedule_to_close_timeout": {"$ref": "#/$defs/nullable_duration"},
            "schedule_to_start_timeout": {"$ref": "#/$defs/nullable_duration"},
            "start_to_close_timeout": {"$ref": "#/$defs/nullable_duration"},
            "heartbeat_timeout": {"$ref": "#/$defs/nullable_duration"},
            "retry_policy": {"oneOf": [{"$ref": "#/$defs/retry_policy"}, {"type": "null"}]},
            "cancellation_type": {"enum": ["try_cancel", "wait_cancellation_completed", "abandon"]},
            "do_not_eagerly_execute": {"type": "boolean"}
          }
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "seq"],
          "properties": {"kind": {"const": "request_cancel_activity"}, "seq": {"$ref": "#/$defs/u32"}}
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "seq", "workflow_id", "workflow_type", "input", "cancellation_type"],
          "description": "Starts a child workflow. Namespace, task queue, timeouts, policies, retry settings, headers, memo, search attributes, versioning, and priority remain Core defaults until the OCaml API exposes them explicitly.",
          "properties": {
            "kind": {"const": "start_child_workflow"},
            "seq": {"$ref": "#/$defs/u32"},
            "workflow_id": {"$ref": "#/$defs/identifier"},
            "workflow_type": {"$ref": "#/$defs/identifier"},
            "input": {"type": "array", "maxItems": 201326592, "items": {"$ref": "#/$defs/payload"}},
            "cancellation_type": {"enum": ["try_cancel", "wait_cancellation_completed", "abandon", "wait_cancellation_requested"]}
          }
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "seq", "reason"],
          "description": "Requests cancellation of a previously started child workflow. Core applies the policy recorded by the start command and retains the reason in history.",
          "properties": {
            "kind": {"const": "cancel_child_workflow"},
            "seq": {"$ref": "#/$defs/u32"},
            "reason": {"$ref": "#/$defs/identifier"}
          }
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "workflow_type", "input"],
          "description": "Ends the current run and starts a fresh run of the named workflow type. The current SDK emits one input payload; the array mirrors Core's repeated argument field.",
          "properties": {
            "kind": {"const": "continue_as_new"},
            "workflow_type": {"$ref": "#/$defs/identifier"},
            "input": {"type": "array", "maxItems": 201326592, "items": {"$ref": "#/$defs/payload"}}
          }
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "seq", "start_to_fire_timeout"],
          "properties": {"kind": {"const": "start_timer"}, "seq": {"$ref": "#/$defs/u32"}, "start_to_fire_timeout": {"$ref": "#/$defs/duration"}}
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "seq"],
          "properties": {"kind": {"const": "cancel_timer"}, "seq": {"$ref": "#/$defs/u32"}}
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "result"],
          "properties": {"kind": {"const": "complete_workflow"}, "result": {"$ref": "#/$defs/nullable_payload"}}
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "failure"],
          "properties": {"kind": {"const": "fail_workflow"}, "failure": {"$ref": "#/$defs/failure"}}
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind"],
          "properties": {"kind": {"const": "cancel_workflow"}}
        }
      ]
    }
  }
}
