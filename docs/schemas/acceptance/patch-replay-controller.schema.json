{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mfow/ocaml-temporal/docs/schemas/acceptance/patch-replay-controller.schema.json",
  "title": "Workflow-patch replay controller evidence",
  "description": "A payload-free, ordered account of the two live source-replacement scenarios. The legacy scenario proves that a marker-free history replays to the old activity branch; the new scenario proves one Core marker and the new activity branch. The shell validator also compares every root identity and exact cross-event relationship that JSON Schema cannot express alone.",
  "type": "object",
  "additionalProperties": false,
  "required": ["legacy_workflow_id", "legacy_run_id", "new_workflow_id", "new_run_id", "events"],
  "properties": {
    "legacy_workflow_id": {"$ref": "#/$defs/identifier"},
    "legacy_run_id": {"$ref": "#/$defs/identifier"},
    "new_workflow_id": {"$ref": "#/$defs/identifier"},
    "new_run_id": {"$ref": "#/$defs/identifier"},
    "events": {
      "type": "array",
      "minItems": 22,
      "maxItems": 22,
      "prefixItems": [
        {"$ref": "#/$defs/stack_ready"},
        {"$ref": "#/$defs/driver_accepted"},
        {"$ref": "#/$defs/history_checked"},
        {"$ref": "#/$defs/worker_stopped"},
        {"$ref": "#/$defs/worker_removed"},
        {"$ref": "#/$defs/worker_ready"},
        {"$ref": "#/$defs/replay_observed"},
        {"$ref": "#/$defs/driver_completed"},
        {"$ref": "#/$defs/history_checked"},
        {"$ref": "#/$defs/worker_stopped"},
        {"$ref": "#/$defs/worker_removed"},
        {"$ref": "#/$defs/driver_accepted"},
        {"$ref": "#/$defs/history_checked"},
        {"$ref": "#/$defs/worker_stopped"},
        {"$ref": "#/$defs/worker_removed"},
        {"$ref": "#/$defs/worker_ready"},
        {"$ref": "#/$defs/replay_observed"},
        {"$ref": "#/$defs/driver_completed"},
        {"$ref": "#/$defs/history_checked"},
        {"$ref": "#/$defs/worker_stopped"},
        {"$ref": "#/$defs/worker_removed"},
        {"$ref": "#/$defs/volume_removed"}
      ],
      "items": false
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 65536,
      "pattern": "^[^\\u0000-\\u001f\\u007f]*$"
    },
    "container_id": {
      "type": "string",
      "minLength": 12,
      "maxLength": 64,
      "pattern": "^[a-f0-9]{12,64}$"
    },
    "positive_count": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1000000
    },
    "nonnegative_count": {
      "type": "integer",
      "minimum": 0,
      "maximum": 1000000
    },
    "positive_signed_64": {
      "type": "string",
      "pattern": "^(?:[1-9][0-9]{0,17}|[1-8][0-9]{18}|9[01][0-9]{17}|92[01][0-9]{16}|922[0-2][0-9]{15}|9223[0-2][0-9]{14}|92233[0-6][0-9]{13}|922337[01][0-9]{12}|92233720[0-2][0-9]{10}|922337203[0-5][0-9]{9}|9223372036[0-7][0-9]{8}|92233720368[0-4][0-9]{7}|922337203685[0-3][0-9]{6}|9223372036854[0-6][0-9]{5}|92233720368547[0-6][0-9]{4}|922337203685477[0-4][0-9]{3}|9223372036854775[0-7][0-9]{2}|922337203685477580[0-6]|9223372036854775807)$"
    },
    "status": {"const": "ok"},
    "scenario": {"enum": ["legacy", "new"]},
    "stack_ready": {
      "type": "object",
      "additionalProperties": false,
      "required": ["step", "status", "stale_project_volumes_before_cleanup", "remaining_project_volumes_before_start", "temporal_healthy"],
      "properties": {
        "step": {"const": "stack_ready"},
        "status": {"$ref": "#/$defs/status"},
        "stale_project_volumes_before_cleanup": {"$ref": "#/$defs/nonnegative_count"},
        "remaining_project_volumes_before_start": {"const": 0},
        "temporal_healthy": {"const": true}
      }
    },
    "driver_accepted": {
      "type": "object",
      "additionalProperties": false,
      "required": ["step", "status", "scenario", "workflow_id", "run_id"],
      "properties": {
        "step": {"const": "driver_accepted"},
        "status": {"$ref": "#/$defs/status"},
        "scenario": {"$ref": "#/$defs/scenario"},
        "workflow_id": {"$ref": "#/$defs/identifier"},
        "run_id": {"$ref": "#/$defs/identifier"}
      }
    },
    "history_checked": {
      "type": "object",
      "additionalProperties": false,
      "required": ["step", "status", "scenario", "stage", "event_count"],
      "properties": {
        "step": {"const": "history_checked"},
        "status": {"$ref": "#/$defs/status"},
        "scenario": {"$ref": "#/$defs/scenario"},
        "stage": {"enum": ["initial", "terminal"]},
        "event_count": {"$ref": "#/$defs/positive_count"}
      }
    },
    "worker_stopped": {
      "type": "object",
      "additionalProperties": false,
      "required": ["step", "status", "scenario", "generation", "container_id", "worker_version", "exit_code", "shutdown_marker"],
      "properties": {
        "step": {"const": "worker_generation_stopped"},
        "status": {"$ref": "#/$defs/status"},
        "scenario": {"$ref": "#/$defs/scenario"},
        "generation": {"enum": [1, 2]},
        "container_id": {"$ref": "#/$defs/container_id"},
        "worker_version": {"enum": ["legacy", "patched"]},
        "exit_code": {"const": 0},
        "shutdown_marker": {"const": true}
      }
    },
    "worker_removed": {
      "type": "object",
      "additionalProperties": false,
      "required": ["step", "status", "scenario", "generation", "container_id", "remaining_worker_containers"],
      "properties": {
        "step": {"const": "worker_generation_removed"},
        "status": {"$ref": "#/$defs/status"},
        "scenario": {"$ref": "#/$defs/scenario"},
        "generation": {"enum": [1, 2]},
        "container_id": {"$ref": "#/$defs/container_id"},
        "remaining_worker_containers": {"const": 0}
      }
    },
    "worker_ready": {
      "type": "object",
      "additionalProperties": false,
      "required": ["step", "status", "scenario", "generation", "container_id", "worker_version", "readiness_generation", "fresh_container"],
      "properties": {
        "step": {"const": "worker_generation_ready"},
        "status": {"$ref": "#/$defs/status"},
        "scenario": {"$ref": "#/$defs/scenario"},
        "generation": {"const": 2},
        "container_id": {"$ref": "#/$defs/container_id"},
        "worker_version": {"const": "patched"},
        "readiness_generation": {"const": 2},
        "fresh_container": {"const": true}
      }
    },
    "replay_observed": {
      "type": "object",
      "additionalProperties": false,
      "required": ["step", "status", "scenario", "generation", "is_replaying", "history_length", "branch", "marker_count"],
      "properties": {
        "step": {"const": "replay_observed"},
        "status": {"$ref": "#/$defs/status"},
        "scenario": {"$ref": "#/$defs/scenario"},
        "generation": {"const": 2},
        "is_replaying": {"const": true},
        "history_length": {"$ref": "#/$defs/positive_signed_64"},
        "branch": {"enum": ["old", "new"]},
        "marker_count": {"enum": [0, 1]}
      }
    },
    "driver_completed": {
      "type": "object",
      "additionalProperties": false,
      "required": ["step", "status", "scenario", "outcome"],
      "properties": {
        "step": {"const": "driver_completed"},
        "status": {"$ref": "#/$defs/status"},
        "scenario": {"$ref": "#/$defs/scenario"},
        "outcome": {"const": "completed"}
      }
    },
    "volume_removed": {
      "type": "object",
      "additionalProperties": false,
      "required": ["step", "status", "remaining_project_volumes"],
      "properties": {
        "step": {"const": "postgres_volume_removed"},
        "status": {"$ref": "#/$defs/status"},
        "remaining_project_volumes": {"const": 0}
      }
    }
  }
}
