{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mfow/ocaml-temporal/blob/master/docs/schemas/bridge/client-terminate-request.schema.json",
  "title": "Exact workflow termination request",
  "type": "object",
  "additionalProperties": false,
  "required": ["namespace", "workflow_id", "run_id", "reason"],
  "properties": {
    "namespace": { "type": "string", "minLength": 1, "maxLength": 65536 },
    "workflow_id": { "type": "string", "minLength": 1, "maxLength": 65536 },
    "run_id": { "type": "string", "minLength": 1, "maxLength": 65536 },
    "reason": { "type": "string", "maxLength": 65536 }
  }
}
