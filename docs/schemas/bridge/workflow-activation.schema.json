{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mfow/ocaml-temporal/docs/schemas/bridge/workflow-activation.schema.json",
  "title": "Workflow activation",
  "description": "A closed semantic activation sent from the Rust Temporal Core bridge to the private OCaml workflow runtime.",
  "type": "object",
  "additionalProperties": false,
  "required": ["run_id", "timestamp", "is_replaying", "history_length", "jobs"],
  "properties": {
    "run_id": {"$ref": "#/$defs/identifier"},
    "timestamp": {"oneOf": [{"$ref": "#/$defs/timestamp"}, {"type": "null"}]},
    "is_replaying": {"type": "boolean"},
    "history_length": {"$ref": "#/$defs/u32"},
    "jobs": {"type": "array", "maxItems": 201326592, "items": {"$ref": "#/$defs/job"}},
    "metadata": {"$ref": "#/$defs/activation_metadata"}
  },
  "$defs": {
    "payload": {"$ref": "temporal-payload.schema.json"},
    "failure": {"$ref": "temporal-failure.schema.json"},
    "identifier": {
      "description": "A nonempty, NUL-free identifier. JSON Schema maxLength counts Unicode code points; both bridge implementations additionally enforce the authoritative 65,536-byte UTF-8 limit.",
      "type": "string",
      "minLength": 1,
      "maxLength": 65536,
      "pattern": "^[^\\u0000]+$"
    },
    "u32": {"type": "integer", "minimum": 0, "maximum": 4294967295},
    "u64_decimal": {"type": "string", "pattern": "^(?:0|[1-9][0-9]{0,19})$"},
    "timestamp": {
      "type": "object",
      "additionalProperties": false,
      "required": ["seconds", "nanoseconds"],
      "properties": {
        "seconds": {"type": "integer", "minimum": -9223372036854775808, "maximum": 9223372036854775807},
        "nanoseconds": {"type": "integer", "minimum": 0, "maximum": 999999999}
      }
    },
    "duration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["seconds", "nanoseconds"],
      "properties": {
        "seconds": {"type": "integer", "minimum": 0, "maximum": 9223372036854775807},
        "nanoseconds": {"type": "integer", "minimum": 0, "maximum": 999999999}
      }
    },
    "initialize_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["headers", "identity", "parent_workflow", "workflow_execution_timeout", "workflow_run_timeout", "workflow_task_timeout", "first_execution_run_id", "start_time", "root_workflow", "priority", "retry_policy", "continuation"],
      "properties": {
        "headers": {"type": "object", "maxProperties": 201326592, "additionalProperties": {"$ref": "#/$defs/payload"}},
        "identity": {"type": "string", "maxLength": 65536},
        "parent_workflow": {"oneOf": [{"$ref": "#/$defs/namespaced_workflow_execution"}, {"type": "null"}]},
        "workflow_execution_timeout": {"oneOf": [{"$ref": "#/$defs/duration"}, {"type": "null"}]},
        "workflow_run_timeout": {"oneOf": [{"$ref": "#/$defs/duration"}, {"type": "null"}]},
        "workflow_task_timeout": {"oneOf": [{"$ref": "#/$defs/duration"}, {"type": "null"}]},
        "first_execution_run_id": {"$ref": "#/$defs/identifier"},
        "start_time": {"oneOf": [{"$ref": "#/$defs/timestamp"}, {"type": "null"}]},
        "root_workflow": {"oneOf": [{"$ref": "#/$defs/workflow_execution"}, {"type": "null"}]},
        "priority": {"oneOf": [{"$ref": "#/$defs/workflow_priority"}, {"type": "null"}]},
        "retry_policy": {"oneOf": [{"$ref": "#/$defs/retry_policy"}, {"type": "null"}]},
        "continuation": {"oneOf": [{"$ref": "#/$defs/continuation"}, {"type": "null"}]}
      }
    },
    "workflow_execution": {
      "type": "object", "additionalProperties": false,
      "required": ["workflow_id", "run_id"],
      "properties": {"workflow_id": {"$ref": "#/$defs/identifier"}, "run_id": {"$ref": "#/$defs/identifier"}}
    },
    "namespaced_workflow_execution": {
      "type": "object", "additionalProperties": false,
      "required": ["namespace", "workflow_id", "run_id"],
      "properties": {"namespace": {"$ref": "#/$defs/identifier"}, "workflow_id": {"$ref": "#/$defs/identifier"}, "run_id": {"$ref": "#/$defs/identifier"}}
    },
    "workflow_priority": {
      "type": "object", "additionalProperties": false,
      "required": ["priority_key", "fairness_key", "fairness_weight_bits"],
      "properties": {
        "priority_key": {"type": "integer", "minimum": 0, "maximum": 2147483647},
        "fairness_key": {"type": "string", "maxLength": 64, "pattern": "^[^\\u0000]*$"},
        "fairness_weight_bits": {"$ref": "#/$defs/u32"}
      }
    },
    "retry_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["initial_interval", "backoff_coefficient_bits", "maximum_interval", "maximum_attempts", "non_retryable_error_types"],
      "properties": {
        "initial_interval": {"$ref": "#/$defs/duration"},
        "backoff_coefficient_bits": {
          "type": "string",
          "pattern": "^(0|[1-9][0-9]{0,19})$",
          "description": "Canonical unsigned 64-bit decimal containing the IEEE-754 bits of a finite backoff coefficient at least 1.0. Runtime validation also enforces the exact unsigned range and floating-point value."
        },
        "maximum_interval": {"$ref": "#/$defs/duration"},
        "maximum_attempts": {"type": "integer", "minimum": 0, "maximum": 2147483647},
        "non_retryable_error_types": {
          "type": "array",
          "maxItems": 201326592,
          "items": {"$ref": "#/$defs/identifier"}
        }
      },
      "description": "The effective retry policy Core applied to this workflow execution."
    },
    "continuation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["continued_from_execution_run_id", "initiator", "continued_failure", "last_completion_result"],
      "properties": {
        "continued_from_execution_run_id": {"$ref": "#/$defs/identifier"},
        "initiator": {"enum": ["unspecified", "workflow", "retry", "cron_schedule"]},
        "continued_failure": {"oneOf": [{"$ref": "#/$defs/failure"}, {"type": "null"}]},
        "last_completion_result": {"oneOf": [{"type": "array", "maxItems": 201326592, "items": {"$ref": "#/$defs/payload"}}, {"type": "null"}]}
      }
    },
    "deployment_version": {
      "type": "object",
      "additionalProperties": false,
      "required": ["deployment_name", "build_id"],
      "properties": {
        "deployment_name": {"type": "string", "maxLength": 65536},
        "build_id": {"$ref": "#/$defs/identifier"}
      }
    },
    "activation_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["available_internal_flags", "history_size_bytes", "continue_as_new_suggested", "deployment_version_for_current_task", "last_sdk_version", "suggest_continue_as_new_reasons", "target_worker_deployment_version_changed"],
      "properties": {
        "available_internal_flags": {"type": "array", "maxItems": 201326592, "items": {"$ref": "#/$defs/u32"}},
        "history_size_bytes": {"$ref": "#/$defs/u64_decimal"},
        "continue_as_new_suggested": {"type": "boolean"},
        "deployment_version_for_current_task": {"oneOf": [{"$ref": "#/$defs/deployment_version"}, {"type": "null"}]},
        "last_sdk_version": {"type": "string", "maxLength": 65536},
        "suggest_continue_as_new_reasons": {"type": "array", "maxItems": 201326592, "items": {"enum": ["unspecified", "history_size_too_large", "too_many_history_events", "too_many_updates"]}},
        "target_worker_deployment_version_changed": {"type": "boolean"}
      }
    },
    "activity_resolution": {
      "oneOf": [
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "payload"],
          "properties": {"kind": {"const": "completed"}, "payload": {"oneOf": [{"$ref": "#/$defs/payload"}, {"type": "null"}]}}
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "failure"],
          "properties": {"kind": {"const": "failed"}, "failure": {"$ref": "#/$defs/failure"}}
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "failure"],
          "properties": {"kind": {"const": "cancelled"}, "failure": {"$ref": "#/$defs/failure"}}
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "attempt", "backoff_duration", "original_schedule_time"],
          "properties": {
            "kind": {"const": "backoff"},
            "attempt": {"$ref": "#/$defs/u32", "minimum": 1},
            "backoff_duration": {"$ref": "#/$defs/duration"},
            "original_schedule_time": {"oneOf": [{"$ref": "#/$defs/timestamp"}, {"type": "null"}]}
          },
          "description": "Core emits this only for a local activity whose retry delay should be represented by a language-owned workflow timer."
        }
      ]
    },
    "child_workflow_start_resolution": {
      "oneOf": [
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "run_id"],
          "properties": {"kind": {"const": "succeeded"}, "run_id": {"$ref": "#/$defs/identifier"}}
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "workflow_id", "workflow_type", "cause"],
          "properties": {
            "kind": {"const": "failed"},
            "workflow_id": {"$ref": "#/$defs/identifier"},
            "workflow_type": {"$ref": "#/$defs/identifier"},
            "cause": {"enum": ["unspecified", "workflow_already_exists"]}
          }
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "failure"],
          "properties": {"kind": {"const": "cancelled"}, "failure": {"$ref": "#/$defs/failure"}}
        }
      ]
    },
    "child_workflow_resolution": {
      "oneOf": [
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "payload"],
          "properties": {"kind": {"const": "completed"}, "payload": {"oneOf": [{"$ref": "#/$defs/payload"}, {"type": "null"}]}}
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "failure"],
          "properties": {"kind": {"const": "failed"}, "failure": {"$ref": "#/$defs/failure"}}
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "failure"],
          "properties": {"kind": {"const": "cancelled"}, "failure": {"$ref": "#/$defs/failure"}}
        }
      ]
    },
    "external_workflow_resolution": {
      "oneOf": [
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind"],
          "properties": {"kind": {"const": "succeeded"}}
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "failure"],
          "properties": {"kind": {"const": "failed"}, "failure": {"$ref": "#/$defs/failure"}}
        }
      ],
      "description": "Reports whether Core delivered an external signal or accepted an external cancellation request. A failure is structured Temporal failure data, not a transport exception."
    },
    "query_workflow": {
      "type": "object", "additionalProperties": false,
      "required": ["kind", "query_id", "query_type", "arguments", "headers"],
      "properties": {
        "kind": {"const": "query_workflow"},
        "query_id": {"$ref": "#/$defs/identifier"},
        "query_type": {"$ref": "#/$defs/identifier"},
        "arguments": {"type": "array", "maxItems": 201326592, "items": {"$ref": "#/$defs/payload"}},
        "headers": {"type": "object", "maxProperties": 201326592, "additionalProperties": {"$ref": "#/$defs/payload"}}
      },
      "description": "A synchronous read-only query request. Core may send several query jobs together; the runtime answers them without running ordinary workflow continuations."
    },
    "update_meta": {
      "type": "object", "additionalProperties": false,
      "required": ["identity", "update_id"],
      "properties": {
        "identity": {"type": "string", "maxLength": 65536},
        "update_id": {"$ref": "#/$defs/identifier"}
      },
      "description": "Requester metadata for a workflow update. update_id must equal the enclosing update id."
    },
    "do_update": {
      "type": "object", "additionalProperties": false,
      "required": ["kind", "id", "protocol_instance_id", "name", "input", "headers", "meta", "run_validator"],
      "properties": {
        "kind": {"const": "do_update"},
        "id": {"$ref": "#/$defs/identifier"},
        "protocol_instance_id": {"$ref": "#/$defs/identifier"},
        "name": {"$ref": "#/$defs/identifier"},
        "input": {"type": "array", "maxItems": 201326592, "items": {"$ref": "#/$defs/payload"}},
        "headers": {"type": "object", "maxProperties": 201326592, "additionalProperties": {"$ref": "#/$defs/payload"}},
        "meta": {"$ref": "#/$defs/update_meta"},
        "run_validator": {"type": "boolean"}
      },
      "description": "A workflow update request. The protocol instance ID correlates responses; run_validator is false while Core replays an already-validated update."
    },
    "job": {
      "oneOf": [
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "workflow_id", "workflow_type", "arguments", "randomness_seed", "attempt"],
          "properties": {
            "kind": {"const": "initialize_workflow"},
            "workflow_id": {"$ref": "#/$defs/identifier"},
            "workflow_type": {"$ref": "#/$defs/identifier"},
            "arguments": {"type": "array", "maxItems": 201326592, "items": {"$ref": "#/$defs/payload"}},
            "randomness_seed": {"$ref": "#/$defs/u64_decimal"},
            "attempt": {"type": "integer", "minimum": 1, "maximum": 2147483647},
            "context": {"$ref": "#/$defs/initialize_context"}
          }
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "seq", "result"],
          "properties": {"kind": {"const": "resolve_activity"}, "seq": {"$ref": "#/$defs/u32"}, "result": {"$ref": "#/$defs/activity_resolution"}}
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "seq", "result"],
          "properties": {"kind": {"const": "resolve_child_workflow_start"}, "seq": {"$ref": "#/$defs/u32"}, "result": {"$ref": "#/$defs/child_workflow_start_resolution"}}
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "seq", "result"],
          "properties": {"kind": {"const": "resolve_child_workflow"}, "seq": {"$ref": "#/$defs/u32"}, "result": {"$ref": "#/$defs/child_workflow_resolution"}}
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "seq", "result"],
          "properties": {"kind": {"const": "resolve_signal_external_workflow"}, "seq": {"$ref": "#/$defs/u32"}, "result": {"$ref": "#/$defs/external_workflow_resolution"}}
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "seq", "result"],
          "properties": {"kind": {"const": "resolve_request_cancel_external_workflow"}, "seq": {"$ref": "#/$defs/u32"}, "result": {"$ref": "#/$defs/external_workflow_resolution"}}
        },
        {"$ref": "#/$defs/query_workflow"},
        {"$ref": "#/$defs/do_update"},
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "signal_name", "input", "identity", "headers"],
          "properties": {
            "kind": {"const": "signal_workflow"},
            "signal_name": {"$ref": "#/$defs/identifier"},
            "input": {"type": "array", "maxItems": 201326592, "items": {"$ref": "#/$defs/payload"}},
            "identity": {"type": "string", "maxLength": 65536},
            "headers": {"type": "object", "maxProperties": 201326592, "additionalProperties": {"$ref": "#/$defs/payload"}}
          }
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "patch_id"],
          "properties": {
            "kind": {"const": "notify_has_patch"},
            "patch_id": {"$ref": "#/$defs/identifier"}
          },
          "description": "History metadata stating that this run already contains the named patch marker. Core orders it before jobs that can run workflow fibers and never places it in a query-only activation."
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "seq"],
          "properties": {"kind": {"const": "fire_timer"}, "seq": {"$ref": "#/$defs/u32"}}
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "reason"],
          "properties": {"kind": {"const": "cancel_workflow"}, "reason": {"type": "string", "maxLength": 65536}}
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "message", "reason"],
          "properties": {
            "kind": {"const": "remove_from_cache"},
            "message": {"type": "string", "maxLength": 65536},
            "reason": {"enum": ["unspecified", "cache_full", "cache_miss", "nondeterminism", "lang_fail", "lang_requested", "task_not_found", "unhandled_command", "fatal", "pagination_or_history_fetch", "workflow_execution_ending"]}
          }
        }
      ]
    }
  }
}
