{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mfow/ocaml-temporal/docs/schemas/acceptance/patch-replay-diagnostics.schema.json",
  "title": "Workflow-patch replay worker diagnostics",
  "description": "The existing Native_worker test observer's payload-free activation records. An initial-stage snapshot contains the generation-one initial record; a terminal-stage snapshot contains that record followed by the generation-two replay record. Patch branch selection is deliberately not duplicated here because it is proven by durable history events.",
  "type": "object",
  "additionalProperties": false,
  "required": ["workflow_id", "run_id", "records"],
  "properties": {
    "workflow_id": {"$ref": "#/$defs/identifier"},
    "run_id": {"$ref": "#/$defs/identifier"},
    "records": {
      "type": "array",
      "minItems": 1,
      "maxItems": 2,
      "items": {"$ref": "#/$defs/record"}
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 65536,
      "pattern": "^[^\\u0000-\\u001f\\u007f]*$"
    },
    "history_length": {
      "type": "string",
      "pattern": "^(?:0|[1-9][0-9]{0,17}|[1-8][0-9]{18}|9[01][0-9]{17}|92[01][0-9]{16}|922[0-2][0-9]{15}|9223[0-2][0-9]{14}|92233[0-6][0-9]{13}|922337[01][0-9]{12}|92233720[0-2][0-9]{10}|922337203[0-5][0-9]{9}|9223372036[0-7][0-9]{8}|92233720368[0-4][0-9]{7}|922337203685[0-3][0-9]{6}|9223372036854[0-6][0-9]{5}|92233720368547[0-6][0-9]{4}|922337203685477[0-4][0-9]{3}|9223372036854775[0-7][0-9]{2}|922337203685477580[0-6]|9223372036854775807)$"
    },
    "record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["phase", "generation", "is_replaying", "history_length"],
      "properties": {
        "phase": {"enum": ["initial", "replay"]},
        "generation": {"type": "integer", "minimum": 1, "maximum": 2147483647},
        "is_replaying": {"type": "boolean"},
        "history_length": {"$ref": "#/$defs/history_length"}
      }
    }
  }
}
