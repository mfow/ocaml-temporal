{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mfow/ocaml-temporal/docs/schemas/bridge/workflow-completion.schema.json",
  "title": "Workflow completion",
  "description": "A closed semantic command batch sent from the private OCaml workflow runtime to the Rust Temporal Core bridge.",
  "type": "object",
  "additionalProperties": false,
  "required": ["run_id", "commands"],
  "properties": {
    "run_id": {"$ref": "#/$defs/identifier"},
    "commands": {"type": "array", "maxItems": 201326592, "items": {"$ref": "#/$defs/command"}}
  },
  "$defs": {
    "payload": {"$ref": "temporal-payload.schema.json"},
    "payload_map": {
      "type": "object",
      "propertyNames": {"$ref": "#/$defs/identifier"},
      "additionalProperties": {"$ref": "#/$defs/payload"},
      "description": "A map of unique search-attribute keys to Temporal payloads. JSON object names provide the uniqueness constraint; both bridge implementations also enforce the identifier byte and NUL rules."
    },
    "failure": {"$ref": "temporal-failure.schema.json"},
    "identifier": {
      "description": "A nonempty, NUL-free identifier. JSON Schema maxLength counts Unicode code points; both bridge implementations additionally enforce the authoritative 65,536-byte UTF-8 limit.",
      "type": "string",
      "minLength": 1,
      "maxLength": 65536,
      "pattern": "^[^\\u0000]+$"
    },
    "u32": {"type": "integer", "minimum": 0, "maximum": 4294967295},
    "duration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["seconds", "nanoseconds"],
      "properties": {
        "seconds": {"type": "integer", "minimum": 0, "maximum": 9223372036854775807},
        "nanoseconds": {"type": "integer", "minimum": 0, "maximum": 999999999}
      }
    },
    "nullable_duration": {"oneOf": [{"$ref": "#/$defs/duration"}, {"type": "null"}]},
    "timestamp": {
      "type": "object",
      "additionalProperties": false,
      "required": ["seconds", "nanoseconds"],
      "properties": {
        "seconds": {"type": "integer", "minimum": -9223372036854775808, "maximum": 9223372036854775807},
        "nanoseconds": {"type": "integer", "minimum": 0, "maximum": 999999999}
      }
    },
    "nullable_timestamp": {"oneOf": [{"$ref": "#/$defs/timestamp"}, {"type": "null"}]},
    "nullable_payload": {"oneOf": [{"$ref": "#/$defs/payload"}, {"type": "null"}]},
    "query_result": {
      "oneOf": [
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "payload"],
          "properties": {"kind": {"const": "succeeded"}, "payload": {"$ref": "#/$defs/payload"}}
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "failure"],
          "properties": {"kind": {"const": "failed"}, "failure": {"$ref": "#/$defs/failure"}}
        }
      ],
      "description": "A successful or failed answer to a synchronous query. A failed query does not fail the workflow execution."
    },
    "update_response": {
      "oneOf": [
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind"],
          "properties": {"kind": {"const": "accepted"}}
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "failure"],
          "properties": {"kind": {"const": "rejected"}, "failure": {"$ref": "#/$defs/failure"}}
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "payload"],
          "properties": {"kind": {"const": "completed"}, "payload": {"$ref": "#/$defs/payload"}}
        }
      ],
      "description": "One phase of a workflow update response. An immediate result can emit accepted followed by completed in the same completion; a later activation may emit completed alone."
    },
    "retry_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["initial_interval", "backoff_coefficient_bits", "maximum_interval", "maximum_attempts", "non_retryable_error_types"],
      "properties": {
        "initial_interval": {"$ref": "#/$defs/duration"},
        "backoff_coefficient_bits": {
          "type": "string",
          "pattern": "^(0|[1-9][0-9]{0,19})$",
          "description": "Canonical unsigned 64-bit decimal containing the IEEE-754 bits of a finite backoff coefficient at least 1.0. Runtime validation also enforces the exact unsigned range and floating-point value."
        },
        "maximum_interval": {"$ref": "#/$defs/duration"},
        "maximum_attempts": {"type": "integer", "minimum": 0, "maximum": 2147483647},
        "non_retryable_error_types": {
          "type": "array",
          "maxItems": 201326592,
          "items": {"$ref": "#/$defs/identifier"}
        }
      },
      "description": "An activity retry policy. The initial interval is positive and the maximum interval is at least as large; zero maximum attempts means unlimited attempts. The coefficient's decimal text is used instead of a JSON number so both language sides preserve its IEEE-754 bits."
    },
    "priority": {
      "type": "object",
      "additionalProperties": false,
      "required": ["priority_key", "fairness_key", "fairness_weight_bits"],
      "properties": {
        "priority_key": {"type": "integer", "minimum": 0, "maximum": 2147483647},
        "fairness_key": {"type": "string", "maxLength": 64, "pattern": "^[^\\u0000]*$"},
        "fairness_weight_bits": {"type": "integer", "minimum": 0, "maximum": 4294967295}
      },
      "description": "Optional Temporal activity scheduling metadata. Zero or empty members request the server defaults; a positive key is ordered before larger keys, and a zero fairness weight requests the default weighting."
    },
    "command": {
      "oneOf": [
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "seq", "activity_id", "activity_type", "task_queue", "arguments", "schedule_to_close_timeout", "schedule_to_start_timeout", "start_to_close_timeout", "heartbeat_timeout", "retry_policy", "priority", "cancellation_type", "do_not_eagerly_execute"],
          "anyOf": [
            {"properties": {"schedule_to_close_timeout": {"not": {"type": "null"}}}},
            {"properties": {"start_to_close_timeout": {"not": {"type": "null"}}}}
          ],
          "properties": {
            "kind": {"const": "schedule_activity"},
            "seq": {"$ref": "#/$defs/u32"},
            "activity_id": {"$ref": "#/$defs/identifier"},
            "activity_type": {"$ref": "#/$defs/identifier"},
            "task_queue": {"$ref": "#/$defs/identifier"},
            "arguments": {"type": "array", "maxItems": 201326592, "items": {"$ref": "#/$defs/payload"}},
            "schedule_to_close_timeout": {"$ref": "#/$defs/nullable_duration"},
            "schedule_to_start_timeout": {"$ref": "#/$defs/nullable_duration"},
            "start_to_close_timeout": {"$ref": "#/$defs/nullable_duration"},
            "heartbeat_timeout": {"$ref": "#/$defs/nullable_duration"},
            "retry_policy": {"oneOf": [{"$ref": "#/$defs/retry_policy"}, {"type": "null"}]},
            "priority": {"oneOf": [{"$ref": "#/$defs/priority"}, {"type": "null"}]},
            "cancellation_type": {"enum": ["try_cancel", "wait_cancellation_completed", "abandon"]},
            "do_not_eagerly_execute": {"type": "boolean"}
          }
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "seq"],
          "properties": {"kind": {"const": "request_cancel_activity"}, "seq": {"$ref": "#/$defs/u32"}}
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "seq", "activity_id", "activity_type", "attempt", "original_schedule_time", "arguments", "schedule_to_close_timeout", "schedule_to_start_timeout", "start_to_close_timeout", "retry_policy", "local_retry_threshold", "cancellation_type"],
          "anyOf": [
            {"properties": {"schedule_to_close_timeout": {"not": {"type": "null"}}}},
            {"properties": {"start_to_close_timeout": {"not": {"type": "null"}}}}
          ],
          "description": "Schedules a worker-local activity. Core executes it without creating a server activity task and records the result in workflow history for replay.",
          "properties": {
            "kind": {"const": "schedule_local_activity"},
            "seq": {"$ref": "#/$defs/u32"},
            "activity_id": {"$ref": "#/$defs/identifier"},
            "activity_type": {"$ref": "#/$defs/identifier"},
            "attempt": {"type": "integer", "minimum": 1, "maximum": 4294967295},
            "original_schedule_time": {"$ref": "#/$defs/nullable_timestamp"},
            "arguments": {"type": "array", "maxItems": 201326592, "items": {"$ref": "#/$defs/payload"}},
            "schedule_to_close_timeout": {"$ref": "#/$defs/nullable_duration"},
            "schedule_to_start_timeout": {"$ref": "#/$defs/nullable_duration"},
            "start_to_close_timeout": {"$ref": "#/$defs/nullable_duration"},
            "retry_policy": {"oneOf": [{"$ref": "#/$defs/retry_policy"}, {"type": "null"}]},
            "local_retry_threshold": {"$ref": "#/$defs/nullable_duration"},
            "cancellation_type": {"enum": ["try_cancel", "wait_cancellation_completed", "abandon"]}
          }
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "seq"],
          "properties": {"kind": {"const": "request_cancel_local_activity"}, "seq": {"$ref": "#/$defs/u32"}},
          "description": "Requests cancellation of a local activity through Core's local activity manager."
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "seq", "workflow_id", "workflow_type", "input", "retry_policy", "cancellation_type"],
          "description": "Starts a child workflow. An optional retry policy is passed to Core. The workflow-level command omits namespace because Rust injects the already validated worker namespace at the Core boundary; task queue, timeouts, close/reuse policies, cron, headers, memo, search attributes, versioning, and priority remain Core defaults until the OCaml API exposes them explicitly.",
          "properties": {
            "kind": {"const": "start_child_workflow"},
            "seq": {"$ref": "#/$defs/u32"},
            "workflow_id": {"$ref": "#/$defs/identifier"},
            "workflow_type": {"$ref": "#/$defs/identifier"},
            "input": {"type": "array", "maxItems": 201326592, "items": {"$ref": "#/$defs/payload"}},
            "retry_policy": {"oneOf": [{"$ref": "#/$defs/retry_policy"}, {"type": "null"}]},
            "cancellation_type": {"enum": ["try_cancel", "wait_cancellation_completed", "abandon", "wait_cancellation_requested"]}
          }
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "seq", "reason"],
          "description": "Requests cancellation of a previously started child workflow. Core applies the policy recorded by the start command and retains the reason in history.",
          "properties": {
            "kind": {"const": "cancel_child_workflow"},
            "seq": {"$ref": "#/$defs/u32"},
            "reason": {"$ref": "#/$defs/identifier"}
          }
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "seq", "workflow_id", "run_id", "signal_name", "input", "child_workflow_only", "headers"],
          "description": "Sends a signal to an external workflow execution. Core resolves the command asynchronously; child_workflow_only selects the parent run's child-workflow target form.",
          "properties": {
            "kind": {"const": "signal_external_workflow"},
            "seq": {"$ref": "#/$defs/u32"},
            "workflow_id": {"$ref": "#/$defs/identifier"},
            "run_id": {"type": "string", "maxLength": 65536, "pattern": "^[^\\u0000]*$"},
            "signal_name": {"$ref": "#/$defs/identifier"},
            "input": {"type": "array", "maxItems": 201326592, "items": {"$ref": "#/$defs/payload"}},
            "child_workflow_only": {"type": "boolean"},
            "headers": {"type": "object", "maxProperties": 201326592, "additionalProperties": {"$ref": "#/$defs/payload"}}
          }
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "seq", "workflow_id", "run_id", "reason"],
          "description": "Requests cancellation of an external workflow execution. Core resolves the command asynchronously and retains the reason for history and diagnostics.",
          "properties": {
            "kind": {"const": "request_cancel_external_workflow"},
            "seq": {"$ref": "#/$defs/u32"},
            "workflow_id": {"$ref": "#/$defs/identifier"},
            "run_id": {"type": "string", "maxLength": 65536, "pattern": "^[^\\u0000]*$"},
            "reason": {"$ref": "#/$defs/identifier"}
          }
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "workflow_type", "input"],
          "description": "Ends the current run and starts a fresh run of the named workflow type. The current SDK emits one input payload; the array mirrors Core's repeated argument field.",
          "properties": {
            "kind": {"const": "continue_as_new"},
            "workflow_type": {"$ref": "#/$defs/identifier"},
            "input": {"type": "array", "maxItems": 201326592, "items": {"$ref": "#/$defs/payload"}}
          }
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "seq", "start_to_fire_timeout"],
          "properties": {"kind": {"const": "start_timer"}, "seq": {"$ref": "#/$defs/u32"}, "start_to_fire_timeout": {"$ref": "#/$defs/duration"}}
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "seq"],
          "properties": {"kind": {"const": "cancel_timer"}, "seq": {"$ref": "#/$defs/u32"}}
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "query_id", "result"],
          "properties": {
            "kind": {"const": "query_result"},
            "query_id": {"$ref": "#/$defs/identifier"},
            "result": {"$ref": "#/$defs/query_result"}
          },
          "description": "Answers one query. Query completions contain only query_result commands and preserve the exact Core query IDs, including the legacy ID."
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "protocol_instance_id", "response"],
          "properties": {
            "kind": {"const": "update_response"},
            "protocol_instance_id": {"$ref": "#/$defs/identifier"},
            "response": {"$ref": "#/$defs/update_response"}
          },
          "description": "Answers a workflow update protocol instance. The protocol ID is not the workflow-visible update ID."
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "patch_id", "deprecated"],
          "properties": {
            "kind": {"const": "set_patch_marker"},
            "patch_id": {"$ref": "#/$defs/identifier"},
            "deprecated": {"type": "boolean"}
          },
          "description": "Records one replay-safe patch lifecycle command. Core owns same-mode marker deduplication, so the language runtime preserves repeated calls in order. Both implementations reject active and deprecated values for the same patch_id within one completion; that cross-element invariant is enforced semantically rather than by this schema."
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "search_attributes"],
          "properties": {
            "kind": {"const": "upsert_search_attributes"},
            "search_attributes": {"$ref": "#/$defs/payload_map"}
          },
          "description": "Merges encoded values into Temporal's indexed workflow search attributes. Keys are unique protocol identifiers and values are ordinary Temporal payloads."
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "result"],
          "properties": {"kind": {"const": "complete_workflow"}, "result": {"$ref": "#/$defs/nullable_payload"}}
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "failure"],
          "properties": {"kind": {"const": "fail_workflow"}, "failure": {"$ref": "#/$defs/failure"}}
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind"],
          "properties": {"kind": {"const": "cancel_workflow"}}
        }
      ]
    }
  }
}
