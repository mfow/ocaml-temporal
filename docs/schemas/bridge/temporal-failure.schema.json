{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mfow/ocaml-temporal/docs/schemas/bridge/temporal-failure.schema.json",
  "title": "Temporal failure",
  "description": "The closed failure subset supported by the first workflow protocol slice.",
  "$ref": "#/$defs/failure",
  "$defs": {
    "payload": {"$ref": "temporal-payload.schema.json"},
    "failure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["message", "source", "stack_trace", "encoded_attributes", "cause", "info"],
      "properties": {
        "message": {"type": "string", "maxLength": 65536},
        "source": {"type": "string", "maxLength": 65536},
        "stack_trace": {"type": "string", "maxLength": 65536},
        "encoded_attributes": {"oneOf": [{"$ref": "#/$defs/payload"}, {"type": "null"}]},
        "cause": {"oneOf": [{"$ref": "#/$defs/failure"}, {"type": "null"}]},
        "info": {"$ref": "#/$defs/info"}
      }
    },
    "info": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "type", "non_retryable", "details"],
          "properties": {
            "kind": {"const": "application"},
            "type": {"type": "string", "maxLength": 65536},
            "non_retryable": {"type": "boolean"},
            "details": {"type": "array", "maxItems": 201326592, "items": {"$ref": "#/$defs/payload"}}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "details", "identity"],
          "properties": {
            "kind": {"const": "canceled"},
            "details": {"type": "array", "maxItems": 201326592, "items": {"$ref": "#/$defs/payload"}},
            "identity": {"type": "string", "maxLength": 65536}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "scheduled_event_id", "started_event_id", "identity", "activity_type", "activity_id", "retry_state"],
          "properties": {
            "kind": {"const": "activity"},
            "scheduled_event_id": {"type": "integer", "minimum": 0, "maximum": 9223372036854775807},
            "started_event_id": {"type": "integer", "minimum": 0, "maximum": 9223372036854775807},
            "identity": {"type": "string", "maxLength": 65536},
            "activity_type": {"type": "string", "minLength": 1, "maxLength": 65536},
            "activity_id": {"type": "string", "minLength": 1, "maxLength": 65536},
            "retry_state": {"enum": ["unspecified", "in_progress", "non_retryable_failure", "timeout", "maximum_attempts_reached", "retry_policy_not_set", "internal_server_error", "cancel_requested"]}
          }
        }
      ]
    }
  }
}
