{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mfow/ocaml-temporal/docs/schemas/acceptance/restart-replay-history.schema.json",
  "title": "Normalized worker restart/replay history",
  "description": "A payload-free projection of one Temporal workflow history used by the restart/replay acceptance controller. The adapter that obtains this document must use a strict JSON parser and preserve the server event order and event IDs.",
  "type": "object",
  "additionalProperties": false,
  "required": ["workflow_id", "run_id", "events"],
  "properties": {
    "workflow_id": {"$ref": "#/$defs/identifier"},
    "run_id": {"$ref": "#/$defs/identifier"},
    "events": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1000000,
      "items": {"$ref": "#/$defs/event"}
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 65536,
      "pattern": "^[^\\u0000-\\u001f\\u007f]*$"
    },
    "event": {
      "type": "object",
      "additionalProperties": false,
      "required": ["event_id", "type"],
      "properties": {
        "event_id": {
          "type": "string",
          "pattern": "^(?:[1-9][0-9]{0,17}|[1-8][0-9]{18}|9[01][0-9]{17}|92[01][0-9]{16}|922[0-2][0-9]{15}|9223[0-2][0-9]{14}|92233[0-6][0-9]{13}|922337[01][0-9]{12}|92233720[0-2][0-9]{10}|922337203[0-5][0-9]{9}|9223372036[0-7][0-9]{8}|92233720368[0-4][0-9]{7}|922337203685[0-3][0-9]{6}|9223372036854[0-6][0-9]{5}|92233720368547[0-6][0-9]{4}|922337203685477[0-4][0-9]{3}|9223372036854775[0-7][0-9]{2}|922337203685477580[0-6]|9223372036854775807)$",
          "description": "Canonical positive signed-64-bit event ID in decimal text. JSON numbers are deliberately avoided because JavaScript-style parsers cannot represent every Temporal event ID exactly."
        },
        "type": {
          "type": "string",
          "enum": [
            "WorkflowExecutionStarted",
            "WorkflowTaskScheduled",
            "WorkflowTaskStarted",
            "WorkflowTaskCompleted",
            "WorkflowTaskFailed",
            "TimerStarted",
            "TimerFired",
            "TimerCanceled",
            "ActivityTaskScheduled",
            "ActivityTaskStarted",
            "ActivityTaskCompleted",
            "ActivityTaskFailed",
            "ActivityTaskCanceled",
            "WorkflowExecutionCompleted",
            "WorkflowExecutionFailed",
            "WorkflowExecutionCanceled",
            "WorkflowExecutionTerminated",
            "WorkflowExecutionTimedOut",
            "WorkflowExecutionContinuedAsNew"
          ]
        }
      }
    }
  }
}
