{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mfow/ocaml-temporal/docs/schemas/bridge/client-error.schema.json",
  "title": "OCaml Temporal native client error body",
  "description": "Closed JSON error body returned in the ABI error buffer for client start and wait operations. Server diagnostic text is deliberately not copied.",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "workflow_id", "existing_run_id"],
      "properties": {
        "kind": {"const": "already_started"},
        "workflow_id": {"type": "string", "minLength": 1, "maxLength": 65536, "pattern": "^[^\\u0000]+$"},
        "existing_run_id": {"anyOf": [{"type": "string", "minLength": 1, "maxLength": 65536, "pattern": "^[^\\u0000]+$"}, {"type": "null"}]}
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "code"],
      "properties": {
        "kind": {"const": "rpc"},
        "code": {
          "description": "Canonical snake_case tonic status code.",
          "enum": [
            "ok",
            "cancelled",
            "unknown",
            "invalid_argument",
            "deadline_exceeded",
            "not_found",
            "already_exists",
            "permission_denied",
            "resource_exhausted",
            "failed_precondition",
            "aborted",
            "out_of_range",
            "unimplemented",
            "internal",
            "unavailable",
            "data_loss",
            "unauthenticated"
          ]
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "code"],
      "properties": {
        "kind": {"const": "protocol"},
        "code": {"enum": ["core_unsupported", "core_invalid"]}
      }
    }
  ]
}
